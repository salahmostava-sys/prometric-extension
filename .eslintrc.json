{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "webextensions": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none" }],
    "no-console": "off",
    "eqeqeq": ["error", "always"],
    "no-eval": "error",
    "no-implicit-globals": "off",
    "prefer-const": "warn",
    "no-var": "error",
    "curly": ["warn", "multi-line"],
    "no-trailing-spaces": "warn",
    "semi": ["warn", "always"],
    "no-multiple-empty-lines": ["warn", { "max": 2 }]
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "coverage/"
  ]
}
